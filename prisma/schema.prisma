// Prisma schema for Arbor CMS
// Uses SQLite for local dev, PostgreSQL-compatible design

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  role      String   @default("superadmin")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([role])
}

model Page {
  id        String   @id @default(cuid())
  parentId  String?
  slug      String
  fullPath  String   @unique
  pageType  String
  status    String   @default("draft")
  content   String   @default("{}")
  sortOrder Int      @default(0)
  showInNav Int      @default(0)
  navLabel  String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  parent   Page?  @relation("PageTree", fields: [parentId], references: [id])
  children Page[] @relation("PageTree")

  @@index([parentId])
  @@index([fullPath])
  @@index([status])
}

model PageTypeSettings {
  id              String   @id @default(cuid())
  pageTypeName    String   @unique
  icon            String   @default("file")
  allowedChildren String   @default("[]")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([pageTypeName])
}

model StorageFile {
  id        String   @id @default(cuid())
  name      String
  path      String   @unique
  mimeType  String
  size      Int
  data      Bytes
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([path])
}

model StorageFolder {
  id        String   @id @default(cuid())
  path      String   @unique
  createdAt DateTime @default(now())

  @@index([path])
}

model SiteSettings {
  id                String   @id @default(cuid())
  navigationEnabled Int      @default(1)
  navigationLogo    String   @default("")
  navigationTitle   String   @default("Arbor CMS")
  footerEnabled     Int      @default(1)
  footerLogo        String   @default("")
  footerText        String   @default("")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}
